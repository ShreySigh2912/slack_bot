# Slack Admission Bot - Environment Variables
# Copy this file to .env and fill in real values

# Required: Slack App credentials
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Optional: OAuth (for /slack/install and /slack/oauth_redirect)
SLACK_CLIENT_ID=1234567890.1234567890
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_REDIRECT_URL=https://YOUR-RENDER-URL.onrender.com/slack/oauth_redirect

# Channel IDs
# The announcement/lobby channel where users join and trigger a DM
ANNOUNCE_CHANNEL_ID=C0123456789
LOBBY_CHANNEL_ID=C0123456789

# Destination batch channels (comma-separated for multiple channels per batch)
# Bot must be a member or have channels:join scope
# Users will be added to ALL channels for their selected batch

# Batch 2 channels (comma-separated)
BATCH2_CHANNEL_IDS=C0BATCH2CH1,C0BATCH2CH2

# Batch 3 channels (comma-separated)
BATCH3_CHANNEL_IDS=C0BATCH3CH1,C0BATCH3CH2

# Batch 4 channels (comma-separated)
BATCH4_CHANNEL_IDS=C0BATCH4CH1,C0BATCH4CH2

# Web server port (Render provides PORT automatically, no need to set)
PORT=3000

# ============================================================================
# RENDER DEPLOYMENT INSTRUCTIONS
# ============================================================================
# 1. Create a new Web Service on Render (https://render.com)
# 2. Connect your GitHub repository
# 3. Configure:
#    - Environment: Node
#    - Build Command: npm install
#    - Start Command: node app.js
# 4. Add all environment variables above in Render Dashboard > Environment
# 5. Render auto-provides PORT - you can omit it from env vars
# 6. After deploy, copy your Render URL and update Slack App settings:
#    - Event Subscriptions > Request URL: https://YOUR-APP.onrender.com/slack/events
#    - OAuth > Redirect URL: https://YOUR-APP.onrender.com/slack/oauth_redirect
